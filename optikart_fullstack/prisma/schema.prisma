// Prisma séma (PostgreSQL) – ez írja le a DB táblákat és kapcsolataikat.
// Futtatás:
// - pnpm prisma:migrate
// - pnpm prisma:generate

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  // Fontos: soha ne tárolj plain-text jelszót – bcrypt hash kerül ide.
  password  String
  role      UserRole  @default(USER)
  createdAt DateTime  @default(now())

  // Kapcsolat: 1 user -> sok booking
  bookings  Booking[] @relation("UserBookings")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  description String?

  // Kapcsolat: 1 category -> sok service
  services    Service[]
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Int      // egyszerűség kedvéért: ár forintban (vagy centben)

  // Kapcsolat: sok service -> 1 category
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  // Kapcsolat: 1 service -> sok booking
  bookings    Booking[]
}

model Booking {
  id        String        @id @default(cuid())

  // Kapcsolat: sok booking -> 1 user (client)
  clientId  String
  client    User          @relation("UserBookings", fields: [clientId], references: [id], onDelete: Cascade)

  // Kapcsolat: sok booking -> 1 service
  serviceId String
  service   Service       @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  startTime DateTime
  endTime   DateTime
  status    BookingStatus @default(PENDING)
  notes     String?
  createdAt DateTime      @default(now())

  @@index([clientId])
  @@index([serviceId])
}

