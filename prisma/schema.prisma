// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum role {
  USER
  ADMIN
}

model User {
  id                   Int                @id @default(autoincrement())
  name                 String?
  email                String             @unique
  phone                String?
  password             String?
  isVerified           Boolean            @default(false)
  twoFactorEnabled     Boolean            @default(false)
  twoFactorSecret      String?
  role                 role               @default(USER)
  emailVerifiedAt      DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime?          @updatedAt
  projects             Project[]
  sentMessages         Message[]          @relation("SentMessages")
  receivedMessages     Message[]          @relation("ReceivedMessages")
  accounts             Account[]
  sessions             Session[]
  analyticsSessions    AnalyticsSession[]
  sentChatMessages     ChatMessage[]      @relation("SentMessages")
  receivedChatMessages ChatMessage[]      @relation("ReceivedMessages")
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  REFUNDED
}

model Cities {
  id   Int     @id @default(autoincrement())
  name String?
  lat  Float?
  lng  Float?
}

model Project {
  id           Int           @id @default(autoincrement())
  name         String?
  description  String?
  location     String?
  chatMessages ChatMessage[]

  totalPrice     Float?
  eventDate      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime?       @updatedAt
  status         ProjectStatus?  @default(PLANNING)
  paymentStatus  PaymentStatus?  @default(PENDING)
  users          User[]
  category       Package?        @relation(fields: [packageId], references: [id])
  packageId      Int?
  type           ProjectType?    @relation(fields: [typeId], references: [id])
  typeId         Int?
  calendarEvents CalendarEvent[]
  galleries      Gallery[]
  messages       Message[]
}

model imagesGalleryWbp {
  id        Int     @id @default(autoincrement())
  fileName  String?
  filePath  String?
  // gallery   Gallery? @relation(fields: [galleryId], references: [id])
  galleryId Int?
}

model imagesFull {
  id        Int      @id @default(autoincrement())
  fileName  String?
  filePath  String?
  gallery   Gallery? @relation(fields: [galleryId], references: [id])
  galleryId Int?
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String?
  packages Package[]
}

model Package {
  id           Int           @id @default(autoincrement())
  name         String?
  description  String?
  subtype      String? // eskuvo: "foto"|"video"|"kombinalt" | portre: "egyeni"|"paros"|"csaladi"
  price        Float?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime?     @updatedAt
  category     Category?     @relation(fields: [categoryId], references: [id])
  categoryId   Int?
  projects     Project[]
  bulletPoints BulletPoint[]
}

model BulletPoint {
  id        Int      @id @default(autoincrement())
  packageId Int?
  title     String?
  package   Package? @relation(fields: [packageId], references: [id])
}

model ProjectType {
  id       Int       @id @default(autoincrement())
  name     String?
  projects Project[]
}

model CalendarEvent {
  id        Int       @id @default(autoincrement())
  title     String?
  wholeDay  Boolean   @default(false)
  startTime DateTime?
  endTime   DateTime?
  project   Project?  @relation(fields: [projectId], references: [id])
  projectId Int?
}

model Gallery {
  id             Int            @id @default(autoincrement())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  title          String?
  description    String?
  coverImageUrl  String? // Cloudinary URL
  projectId      Int
  project        Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  shareToken     String         @unique @default(cuid())
  isPublic       Boolean        @default(false)
  password       String? // bcrypt hash
  expiresAt      DateTime?
  images         GalleryImage[]
  imagesFull     imagesFull[]
  googleDriveUrl String? // hosszú távú archív link adminból beállítható
  videos         GalleryVideo[]
}

model GalleryImage {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  galleryId Int
  gallery   Gallery  @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  publicId     String
  originalUrl  String
  thumbnailUrl String
  previewUrl   String
  fileName     String?
  width        Int?
  height       Int?
  bytes        Int?
  sortOrder    Int     @default(0)
}

model Image {
  id       Int     @id @default(autoincrement())
  fileName String?
  filePath String?
}

model Message {
  id          Int      @id @default(autoincrement())
  project     Project? @relation(fields: [projectId], references: [id])
  projectId   Int?
  sender_id   Int
  receiver_id Int
  sender      User     @relation("SentMessages", fields: [sender_id], references: [id])
  receiver    User     @relation("ReceivedMessages", fields: [receiver_id], references: [id])
  content     String?
  createdAt   DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id      Int      @id @default(autoincrement())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model AnalyticsSession {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())
  duration   Int? // másodpercekben, session végén frissítve

  // Látogató adatok
  userAgent   String?
  device      String? // "mobile" | "tablet" | "desktop"
  browser     String? // "chrome" | "firefox" | "safari" | "edge" | "other"
  os          String? // "windows" | "macos" | "ios" | "android" | "linux" | "other"
  country     String? // IP alapján (opcionális, ha nincs geo lib, null)
  referrer    String? // honnan jött
  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  // Azonosítás
  userId Int? // ha be van jelentkezve
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  events AnalyticsEvent[]
}

model AnalyticsEvent {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  sessionId String
  session   AnalyticsSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Esemény típusa
  // "pageview" | "click" | "wizard_step" | "wizard_complete" | "wizard_exit"
  // "project_created" | "form_submit" | "gallery_view" | "contact_open"
  type String

  // Oldal / útvonal ahol történt
  page String? // pl. "/weddings", "/contact", "/user/projects/3"

  // Extra adat JSON-ban (pl. {"step": 2, "typeId": "eskuvo", "packageId": 5})
  meta Json?
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Ki írta
  senderId Int
  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  // Kinek (null = adminnak szóló standalone üzenet)
  recipientId Int?
  recipient   User? @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: SetNull)

  // Tartalom
  body String

  // Kapcsolat projekttel (opcionális)
  projectId Int?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Státusz
  isRead       Boolean @default(false)
  isAdminReply Boolean @default(false) // admin válasz-e

  // Thread: válasz egy korábbi üzenetre
  parentId Int?
  parent   ChatMessage?  @relation("Thread", fields: [parentId], references: [id], onDelete: SetNull)
  replies  ChatMessage[] @relation("Thread")
}

model GuestChatSession {
  id        String   @id @default(cuid()) // localStorage-ban tárolt token
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name  String
  email String

  messages GuestChatMessage[]
}

model GuestChatMessage {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  sessionId String
  session   GuestChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  body         String
  isAdminReply Boolean @default(false)
  isRead       Boolean @default(false) // guest olvasta-e az admin választ
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  email     String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model GalleryVideo {
  id        Int     @id @default(autoincrement())
  galleryId Int
  gallery   Gallery @relation(fields: [galleryId], references: [id])

  publicId     String // Cloudinary public_id
  originalUrl  String // Cloudinary secure_url (stream)
  streamUrl    String // HLS vagy MP4 stream URL
  thumbnailUrl String? // Cloudinary video thumbnail
  fileName     String?
  bytes        Int?
  duration     Float? // másodpercben
  width        Int?
  height       Int?
  format       String? // mp4, mov, stb.

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([galleryId])
}
